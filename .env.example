# Memoir Environment Variables

# Override config settings
MEMOIR_BASE_DIR=./data
MEMOIR_LLM_PROVIDER=ollama

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# OpenAI settings (if using openai provider)
OPENAI_API_KEY=your-api-key-here

# Server settings
MEMOIR_HOST=0.0.0.0
MEMOIR_PORT=8000
